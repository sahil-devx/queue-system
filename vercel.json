{
  "version": 2,
  "name": "queue-system-frontend",
  "builds": [
    {
      "src": "frontend/vite-project/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend/vite-project/dist/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "https://queue-system-api.onrender.com"
  }
}
